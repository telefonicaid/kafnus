{
  "name": "not_servicepath_case",
  "fiware-service": "test",
  "fiware-servicepath": "",
  "subscriptions": {
    "historic": {
      "description": "Sensor:HISTORIC:not_servicepath:historic",
      "status": "active",
      "subject": {
        "entities": [
          {
            "idPattern": ".*",
            "type": "Sensor"
          }
        ],
        "condition": {
          "attrs": [
            "TimeInstant"
          ]
        }
      },
      "notification": {
        "kafkaCustom": {
          "url": "kafka://kafka:29092",
          "topic": "smc_raw_historic",
          "headers": {
            "fiware-datamodel": "dm-by-entity-type-database"
          }
        },
        "attrs": [
          "TimeInstant",
          "temperature"
        ]
      }
    },
    "lastdata": {
      "description": "Sensor:LASTDATA:not_servicepath:lastdata",
      "status": "active",
      "subject": {
        "entities": [
          {
            "idPattern": ".*",
            "type": "Sensor"
          }
        ],
        "condition": {
          "attrs": [
            "TimeInstant"
          ]
        }
      },
      "notification": {
        "kafkaCustom": {
          "url": "kafka://kafka:29092",
          "topic": "smc_raw_lastdata",
          "headers": {
            "fiware-datamodel": "dm-by-entity-type-database"
          }
        },
        "attrs": [
          "TimeInstant",
          "temperature"
        ]
      }
    },
    "mutable": {
      "description": "Sensor:mutable:not_servicepath:mutable",
      "status": "active",
      "subject": {
        "entities": [
          {
            "idPattern": ".*",
            "type": "Sensor"
          }
        ],
        "condition": {
          "attrs": [
            "TimeInstant"
          ]
        }
      },
      "notification": {
        "kafkaCustom": {
          "url": "kafka://kafka:29092",
          "topic": "smc_raw_mutable",
          "headers": {
            "fiware-datamodel": "dm-by-entity-type-database"
          }
        },
        "attrs": [
          "TimeInstant",
          "temperature"
        ]
      }
    }
  },
  "updateEntities": [
    {
      "id": "Sensor1",
      "type": "Sensor",
      "TimeInstant": {
        "type": "DateTime",
        "value": "2025-06-26T11:00:00Z"
      },
      "temperature": {"value": 25.0, "type": "Float"}
    },
    {
      "id": "Sensor1",
      "type": "Sensor",
      "TimeInstant": {
        "type": "DateTime",
        "value": "2025-06-26T12:00:00Z"
      },
      "temperature": {"value": 26.0, "type": "Float"}
    }
  ]
}
